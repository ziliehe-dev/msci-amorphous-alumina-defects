# ============================================================
# Random-start melt of liquid Al2O3
# 1000 atoms × 10 independent samples
# units metal | Matsui 1994 | timestep = 1 fs
# ============================================================

variable i loop 10
label loop_samples

clear
log log_melt_1000_${i}.txt

# ---------- Units & styles ----------
units           metal
atom_style      charge
boundary        p p p
timestep        0.001     # 1 fs

neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes

# ---------- Simulation box ----------
variable L equal 47
region box block 0 ${L} 0 ${L} 0 ${L} units box
create_box 2 box

# ---------- Random seeds ----------
variable seed1 equal 12345 + 1000*${i}
variable seed2 equal 67890 + 1000*${i}

# ---------- Create random structure ----------
create_atoms 1 random 400 ${seed1} box overlap 1.0 maxtry 500
create_atoms 2 random 600 ${seed2} box overlap 1.0 maxtry 500

# ---------- Masses ----------
mass 1 26.9815
mass 2 15.9994

# ---------- Charges (Matsui) ----------
set type 1 charge  1.4175
set type 2 charge -0.9450

# ---------- Potential ----------
pair_style      buck/coul/long 12.0
kspace_style    ewald 1.0e-6

pair_coeff  1 1   3.1571e7   0.0680   14.051
pair_coeff  1 2   2.8477e4   0.1720   34.578
pair_coeff  2 2   6462.7     0.2760   85.093

# ---------- Thermo ----------
thermo_style    custom step temp press vol pe etotal density
thermo          1000

# ============================================================
# Step A: Heat 300 -> 3000 K 
# 30 ps = 30000 steps
# ============================================================

velocity all create 300.0 ${seed1} mom yes rot yes dist gaussian

fix heat all npt temp 300.0 3000.0 0.1 iso 0.0 0.0 1.0
run 30000
unfix heat

# ============================================================
# Step B: Anneal at 3000 K
# 40 ps = 40000 steps
# ============================================================

fix anneal all npt temp 3000.0 3000.0 0.1 iso 0.0 0.0 1.0
run 40000
unfix anneal

# ============================================================
# Step C: MSD check at 3000 K
# 100 ps = 100000 steps
# ============================================================

group Al type 1
group O  type 2

reset_timestep 0

compute msd_Al Al msd
compute msd_O  O  msd
compute msd_all all msd

fix msd_out all ave/time 200 1 200 c_msd_Al[4] c_msd_O[4] c_msd_all[4] file msd_3000K_1000_sample${i}.txt

fix msd_run all npt temp 3000.0 3000.0 0.1 iso 0.0 0.0 1.0
run 100000

unfix msd_run
unfix msd_out
uncompute msd_Al
uncompute msd_O
uncompute msd_all


# ============================================================
# Step D: Write liquid snapshot
# ============================================================

write_data liquid_3000K_1000_sample${i}.data

next i
jump SELF loop_samples
